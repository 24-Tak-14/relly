# Description: Defines the Team class and functions to load league data.

import random
import uuid

class Player:
    """A placeholder for the Player class."""
    def __init__(self, x, y, team, name, attributes, color, position=None):
        self.id = str(uuid.uuid4())
        self.x = x
        self.y = y
        self.team = team
        self.name = name
        self.attributes = attributes
        self.color = color
        self.position = position

class Team:
    """
    Represents a football team in the game.

    This class provides the functionality to manage a team's roster,
    financials (salary cap), and player assignments.
    """
    def __init__(self, name: str, max_salary_cap: int, data: dict):
        """
        Initializes a new Team instance.

        Args:
            name (str): The name of the team.
            max_salary_cap (int): The maximum allowed salary for the team.
            data (dict): The original JSON data for this team.
        """
        self.name = name
        self.roster = []  # A list to hold Player objects.
        self.max_salary_cap = max_salary_cap
        self.current_salary_spend = 0
        self.data = data # Store the original data for easy access.

    def add_player(self, player) -> bool:
        """
        Adds a player to the team's roster, checking against the salary cap.

        Args:
            player (Player): The Player object to add.

        Returns:
            bool: True if the player was added successfully, False otherwise.
        """
        # A simple placeholder for player salary.
        player_salary = random.randint(500, 2000)

        if self.current_salary_spend + player_salary <= self.max_salary_cap:
            self.roster.append(player)
            self.current_salary_spend += player_salary
            print(f"Added {player.name} to {self.name}. Roster size: {len(self.roster)}")
            return True
        else:
            print(f"Cannot add {player.name}. The team is over the salary cap.")
            return False

    def remove_player(self, player_id: str):
        """
        Removes a player from the team's roster by their unique ID.

        Args:
            player_id (str): The unique ID of the player to remove.
        """
        player_to_remove = next((p for p in self.roster if p.id == player_id), None)
        if player_to_remove:
            # Re-calculate salary after removal.
            self.current_salary_spend -= random.randint(500, 2000)
            self.roster.remove(player_to_remove)
            print(f"Player with ID {player_id} was removed from {self.name}.")
        else:
            print(f"Error: Player with ID {player_id} not found on the {self.name} roster.")

    def get_roster_size(self) -> int:
        """
        Returns the current number of players on the roster.
        """
        return len(self.roster)

def create_teams_from_data(teams_data: list) -> list[Team]:
    """
    Creates a list of Team objects from a list of team data dictionaries.

    Args:
        teams_data (list): A list of dictionaries, where each dictionary
                           represents a team.

    Returns:
        list[Team]: A list of initialized Team objects.
    """
    teams = []
    for team_dict in teams_data:
        # A simple placeholder salary cap for demonstration.
        # This can be made more dynamic later.
        team_name = team_dict.get('team_name', 'Unnamed Team')
        stadium_capacity = team_dict.get('stadium', {}).get('capacity', 50000)
        max_salary_cap = stadium_capacity * 100 # A simple formula for now.
        
        team = Team(name=team_name, max_salary_cap=max_salary_cap, data=team_dict)
        teams.append(team)
    return teams

