# systems/ultimate_team/hut_marketplace.py
import time
from collections import defaultdict

class HUTMarketplace:
    def __init__(self, ultimate_team_manager):
        self.ultimate_team_manager = ultimate_team_manager
        self.active_listings = {}
        self.listing_counter = 0
        self.transaction_fee_rate = 0.05
        self.store_packs = {
            "starter_pack": {"price": 100, "contents": [{"type": "player_card", "player_id": "hut_rb_dixon_iron"}, {"type": "mod", "mod_id": "basic_speed_mod"}]},
            "gold_pack": {"price": 500, "contents": [{"type": "player_card", "player_id": "hut_wr_legend_d_myles_zori"}]},
        }

    def _generate_listing_id(self):
        self.listing_counter += 1
        return f"listing_{self.listing_counter}"

    def list_item(self, seller_id, player_card, start_price, buy_now_price=None, duration_hours=24):
        if not self.ultimate_team_manager.remove_player_from_inventory(seller_id, player_card.player_id):
            print(f"Error: Player card {player_card.name} not in seller's inventory.")
            return None
        listing_id = self._generate_listing_id()
        end_time = time.time() + (duration_hours * 3600)
        self.active_listings[listing_id] = {
            "item_id": player_card.player_id,
            "seller_id": seller_id,
            "start_price": start_price,
            "buy_now_price": buy_now_price,
            "end_time": end_time,
            "current_bid": start_price,
            "highest_bidder_id": None,
            "item_type": "player_card"
        }
        print(f"Item '{player_card.name}' listed by {seller_id} (ID: {listing_id}).")
        return listing_id

    def place_bid(self, bidder_id, listing_id, bid_amount):
        listing = self.active_listings.get(listing_id)
        if not listing:
            print("Error: Listing not found.")
            return False
        if time.time() > listing['end_time']:
            print("Error: Listing has ended.")
            return False
        if bid_amount <= listing['current_bid']:
            print(f"Error: Bid must be higher than current bid ({listing['current_bid']}).")
            return False
        if bidder_id == listing['seller_id']:
            print("Error: Cannot bid on your own item.")
            return False
        listing['current_bid'] = bid_amount
        listing['highest_bidder_id'] = bidder_id
        print(f"Bid of {bid_amount} placed on {listing['item_id']} by {bidder_id}.")
        return True

    def buy_now(self, buyer_id, listing_id):
        listing = self.active_listings.get(listing_id)
        if not listing:
            print("Error: Listing not found.")
            return False
        if time.time() > listing['end_time']:
            print("Error: Listing has ended.")
            return False
        if not listing['buy_now_price']:
            print("Error: No 'Buy Now' option for this listing.")
            return False
        if buyer_id == listing['seller_id']:
            print("Error: Cannot buy your own item.")
            return False
        price = listing['buy_now_price']
        print(f"Item '{listing['item_id']}' bought instantly by {buyer_id} for {price}.")
        self._resolve_listing_sale(listing_id, buyer_id, price)
        return True

    def _resolve_listing_sale(self, listing_id, buyer_id, final_price):
        listing = self.active_listings.pop(listing_id)
        seller_id = listing['seller_id']
        item_id = listing['item_id']
        net_to_seller = final_price * (1 - self.transaction_fee_rate)
        fee_amount = final_price * self.transaction_fee_rate
        player_card_obj = self.ultimate_team_manager.get_player_card_template(item_id)
        if player_card_obj:
            self.ultimate_team_manager.add_player_to_inventory(buyer_id, player_card_obj.player_id)
            print(f"Item '{item_id}' transferred to {buyer_id}'s inventory.")
        else:
            print(f"Warning: Could not find item template for {item_id}.")
        print(f"Seller {seller_id} received {net_to_seller} HUT points (Fee: {fee_amount}).")

    def resolve_expired_listings(self):
        expired_listings_ids = [
            listing_id for listing_id, listing in self.active_listings.items()
            if time.time() > listing['end_time']
        ]
        for listing_id in expired_listings_ids:
            listing = self.active_listings[listing_id]
            if listing['highest_bidder_id']:
                print(f"Listing {listing_id} expired. Sold to {listing['highest_bidder_id']} for {listing['current_bid']}.")
                self._resolve_listing_sale(listing_id, listing['highest_bidder_id'], listing['current_bid'])
            else:
                self.active_listings.pop(listing_id)
                player_card_obj = self.ultimate_team_manager.get_player_card_template(listing['item_id'])
                if player_card_obj:
                    self.ultimate_team_manager.add_player_to_inventory(listing['seller_id'], player_card_obj.player_id)
                    print(f"Listing {listing_id} expired with no bids. Item returned to {listing['seller_id']}.")
                else:
                    print(f"Warning: Listing {listing_id} expired, item {listing['item_id']} couldn't be returned.")

    def get_active_listings(self):
        return list(self.active_listings.values())

    def get_user_listings(self, user_id):
        return [listing for listing in self.active_listings.values() if listing['seller_id'] == user_id]

    def buy_pack(self, user_id, pack_id):
        pack_info = self.store_packs.get(pack_id)
        if not pack_info:
            print("Error: Pack not found.")
            return False
        print(f"User {user_id} bought {pack_id} for {pack_info['price']} HUT points.")
        for item_data in pack_info['contents']:
            if item_data['type'] == 'player_card':
                self.ultimate_team_manager.add_player_to_inventory(user_id, item_data['player_id'])
            elif item_data['type'] == 'mod':
                print(f"  - Received Mod: {item_data['mod_id']}")
        return True
