# buzznd.py - Sports Media Engine (Unfiltered)

import random
from typing import Dict, List

class BuzznD:
    def __init__(self):
        self.media_outlets = {
            "newspapers": ["The Daily Blitz", "Gridiron Gazette", "Sunday Scaries"],
            "podcasts": ["No Mercy Sports", "Tough Talk Football", "The Bleacher Report"]
        }

        self.question_templates = {
            "winning": [
                "Coach, now that you've managed to fluke out a win, how long before your inevitable collapse back into mediocrity?",
                "{player}, is it true your performance only improved because you finally stopped partying the night before games?",
                "Given the refs practically handed you this victory, do you even consider it legitimate?",
                "Do you think the other team just gave up halfway through, or was this actually part of your plan?",
                "Are you shocked the fans still show up despite your track record?",
                "{player}, did your PR team prep that 'hero' speech or did you improvise it poorly yourself?",
                "Does this win change anything, or are you still a joke in the division?",
                "Coach, was the victory part of a divine miracle or a clerical error?",
                "{player}, do you even understand what went right, or are you still confused?",
                "Do you think your opponent just underestimated how mediocre you are?"
            ],
            "losing": [
                "{player}, sources say your teammates openly mock your abilities. Care to comment on the locker room discord?",
                "Coach, your play-calling was an absolute dumpster fire. Are you actively trying to get fired?",
                "Knowing your career is circling the drain, what kind of reality show are you planning to star in next?",
                "{player}, after that abysmal performance, do you think your wife still respects you?",
                "Coach, given your consistent failures, have you considered that you're simply not cut out for this?",
                "This team is an embarrassment to the city. Who is the most to blame, and why is it you?",
                "Would you say the team gave up before or after the first quarter?",
                "{player}, did you practice at all this week, or was Netflix your main opponent?",
                "Coach, were you watching the same game as everyone else?",
                "Are you guys even aware this was a professional football game?"
            ],
            "scandal": [
                "{player}, how much did you pay her to keep quiet about that incident?",
                "Coach, is it true you're losing the locker room over your 'special' relationship with the team's masseuse?",
                "With rumors swirling about illegal gambling, are you surprised the FBI hasn't raided the facility yet?",
                "Do you have any comments on the leaked DMs showing team drama?",
                "{player}, care to explain the late-night photos that surfaced this morning?",
                "Coach, how do you defend signing a player with three ongoing lawsuits?",
                "Do you think scandal is just part of the team's brand at this point?",
                "When did the team decide PR disasters were a weekly feature?",
                "Are you all trying to be the next reality show, or is this still football?",
                "What would it take to make headlines for winning instead of scandal?"
            ],
            "injury": [
                "{player}, doctors are saying your injury might be career-ending. Are you prepared to face a life of irrelevance?",
                "Coach, are you concerned about the long-term health risks you're exposing your players to with your brutal training regimen?",
                "Given your history of injuries, do you think your body is trying to tell you something, like 'quit'?",
                "Was this injury a result of poor conditioning or sheer incompetence?",
                "Is the medical staff even qualified to wrap an ankle at this point?",
                "How much longer before this team becomes an injury reserve list?",
                "Would you blame the field conditions or just poor genetics?",
                "Coach, is sacrificing players for ratings worth it?",
                "{player}, how long are you planning to milk this injury for sympathy?",
                "Do you think fans even noticed you were gone, or is that part of the pain too?"
            ]
        }

    def generate_press_questions(self, team: Dict, game_result: Dict) -> List[str]:
        questions = []
        key = game_result.get("outcome", "losing")
        style = self.question_templates.get(key, self.question_templates["losing"])
        for _ in range(3):
            template = random.choice(style)
            questions.append(template.format(player=team.get("key_player", "[Player]")))
        return questions

    def generate_article(self, team: Dict, event: Dict) -> Dict:
        headline = f"{team['name']} {event['outcome']}: {random.choice(['Pathetic', 'Embarrassing', 'Shameful'])} Display"
        return {
            "headline": headline,
            "body": self._generate_article_body(team, event),
            "outlet": random.choice(self.media_outlets['newspapers'])
        }

    def _generate_article_body(self, team: Dict, event: Dict) -> str:
        return f"The {team['name']} showed complete incompetence on and off the field. Fans are questioning if this is even a real team anymore."


# Example CLI Output for 'runball' GUI can trigger this
