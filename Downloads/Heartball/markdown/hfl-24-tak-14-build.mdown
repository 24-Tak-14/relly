# systems/ultimate_team/hut_event_scheduler.py
import time
from datetime import datetime, timedelta

class HUTEventScheduler:
    def __init__(self, ultimate_team_manager):
        self.ultimate_team_manager = ultimate_team_manager
        self.events = {}
        self.active_events = {}

    def define_event(self, event_id, event_type, name, description, start_time_str, end_time_str, rewards, criteria):
        try:
            start_time = datetime.strptime(start_time_str, "%Y-%m-%d %H:%M:%S")
            end_time = datetime.strptime(end_time_str, "%Y-%m-%d %H:%M:%S")
        except ValueError:
            print("Error: Invalid date/time format. Use YYYY-MM-DD HH:MM:SS.")
            return False
        if event_id in self.events:
            print(f"Error: Event ID '{event_id}' already exists.")
            return False
        self.events[event_id] = {
            "event_type": event_type,
            "name": name,
            "description": description,
            "start_time": start_time,
            "end_time": end_time,
            "rewards": rewards,
            "criteria": criteria,
            "status": "defined"
        }
        print(f"Event '{name}' ({event_id}) defined.")
        return True

    def _check_event_status(self, event_id):
        event = self.events.get(event_id)
        if not event:
            return "not_found"
        now = datetime.now()
        if now >= event['start_time'] and now < event['end_time']:
            if event['status'] != "active":
                event['status'] = "active"
                self.active_events[event_id] = event
                print(f"Event '{event['name']}' is now ACTIVE.")
            return "active"
        elif now >= event['end_time']:
            if event['status'] != "completed":
                event['status'] = "completed"
                if event_id in self.active_events:
                    del self.active_events[event_id]
                print(f"Event '{event['name']}' has ENDED.")
            return "completed"
        else:
            if event['status'] != "scheduled":
                event['status'] = "scheduled"
                if event_id in self.active_events:
                    del self.active_events[event_id]
            return "scheduled"

    def update_all_event_statuses(self):
        for event_id in list(self.events.keys()):
            self._check_event_status(event_id)

    def get_active_events(self):
        self.update_all_event_statuses()
        return list(self.active_events.values())

    def distribute_event_rewards(self, event_id, participants_data):
        event = self.events.get(event_id)
        if not event or event['status'] != "completed":
            print(f"Error: Event '{event_id}' is not completed or does not exist.")
            return False
        print(f"Distributing rewards for event '{event['name']}'...")
        for participant in participants_data:
            user_id = participant['user_id']
            user_performance = participant['performance']
            meets_criteria = True
            for criterion_key, required_value in event['criteria'].items():
                if user_performance.get(criterion_key, 0) < required_value:
                    meets_criteria = False
                    break
            if meets_criteria:
                print(f"  - User {user_id} met criteria. Granting rewards...")
                for reward in event['rewards']:
                    if reward['type'] == 'HUT_POINTS':
                        print(f"    - Granted {reward['amount']} HUT points to {user_id}")
                    elif reward['type'] == 'player_card':
                        self.ultimate_team_manager.add_player_to_inventory(user_id, reward['player_id'])
                        print(f"    - Granted player card '{reward['player_id']}' to {user_id}")
            else:
                print(f"  - User {user_id} did not meet criteria for rewards.")
        event['rewards_distributed'] = True
        return True
