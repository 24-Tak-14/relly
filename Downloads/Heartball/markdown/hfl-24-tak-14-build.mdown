// dashboard/static/js/scripts.js
async function fetchData(url) {
    const response = await fetch(url);
    return response.json();
}

async function createRoster() {
    const userId = document.getElementById('user-id').value;
    const rosterName = document.getElementById('roster-name').value;
    const response = await fetch(`/roster/${userId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ roster_name: rosterName })
    });
    const result = await response.json();
    alert(`Roster created: ${result.roster_id}`);
    loadRoster(userId, result.roster_id);
}

async function loadRoster(userId, rosterId) {
    try {
        const roster = await fetchData(`/roster/${userId}/${rosterId}`);
        const rosterDisplay = document.getElementById('roster-display');
        rosterDisplay.innerHTML = `
            <h3 class="text-lg font-semibold">${roster.roster_name}</h3>
            <ul class="mt-2">
                ${roster.players.map(p => `
                    <li class="p-2 border-b">${p.name} (${p.position}, ${p.rarity}, OVR ${p.base_stats.overall})</li>
                `).join('')}
            </ul>
        `;
    } catch (error) {
        console.error('Error loading roster:', error);
    }
}

async function loadMarketplace() {
    try {
        const listings = await fetchData('/marketplace/listings');
        const marketplaceDisplay = document.getElementById('marketplace-display');
        marketplaceDisplay.innerHTML = `
            <ul class="mt-2">
                ${listings.map(l => `
                    <li class="p-2 border-b">Item: ${l.item_id}, Current Bid: ${l.current_bid}, Buy Now: ${l.buy_now_price || 'N/A'}</li>
                `).join('')}
            </ul>
        `;
    } catch (error) {
        console.error('Error loading marketplace:', error);
    }
}

async function loadFoundry(userId) {
    try {
        const parts = await fetchData(`/foundry/parts/${userId}`);
        const blueprints = await fetchData(`/foundry/craftable_blueprints/${userId}`);
        document.getElementById('foundry-parts').innerHTML = `
            <h3 class="text-lg font-semibold">Foundry Parts</h3>
            <ul class="mt-2">
                ${Object.entries(parts).map(([id, qty]) => `<li class="p-2 border-b">${id}: ${qty}</li>`).join('')}
            </ul>
        `;
        document.getElementById('craftable-blueprints').innerHTML = `
            <h3 class="text-lg font-semibold">Craftable Blueprints</h3>
            <ul class="mt-2">
                ${blueprints.map(bp => `<li class="p-2 border-b">${bp.name}: ${bp.description}</li>`).join('')}
            </ul>
        `;
    } catch (error) {
        console.error('Error loading foundry:', error);
    }
}

async function disenchantItem() {
    const userId = document.getElementById('user-id').value;
    const itemId = document.getElementById('disenchant-item-id').value;
    try {
        const response = await fetch('/foundry/disenchant', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: userId, item_type: 'player_card', item_id: itemId })
        });
        const result = await response.json();
        alert(result.message);
        loadFoundry(userId);
    } catch (error) {
        console.error('Error disenchanting item:', error);
    }
}

async function craftPlayer() {
    const userId = document.getElementById('user-id').value;
    const blueprintId = document.getElementById('blueprint-id').value;
    try {
        const response = await fetch('/foundry/craft', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: userId, blueprint_id: blueprintId })
        });
        const result = await response.json();
        alert(result.message);
        loadFoundry(userId);
    } catch (error) {
        console.error('Error crafting player:', error);
    }
}

document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
        e.preventDefault();
        document.querySelectorAll('section').forEach(section => section.classList.add('hidden'));
        document.querySelector(link.getAttribute('href')).classList.remove('hidden');
        if (link.getAttribute('href') === '#marketplace') loadMarketplace();
        if (link.getAttribute('href') === '#foundry') loadFoundry(document.getElementById('user-id').value || 'test_user_001');
    });
});

