            frozenset(["Team Leader", "Superstar"]): {"name": "Inspirational Leadership", "bonus_type": "flat", "amount": 3, "target_stat": "overall_team_morale"},
            frozenset(["Rookie Sensation", "Aggressive Runner"]): {"name": "Fresh Legs Boost", "bonus_type": "percentage", "amount": 0.02, "target_stat": "stamina_regeneration"},
        }
        self.bonus_application_rules = {
            "passing_yards_gain": "multiplicative",
            "overall_team_morale": "additive",
            "stamina_regeneration": "additive",
        }

    def calculate_chemistry_bonuses(self, roster_players):
        active_bonuses = []
        for rule_tags_frozenset, bonus_info in self.chemistry_rules.items():
            all_tags_present = True
            for tag in rule_tags_frozenset:
                if tag not in [p_tag for p in roster_players for p_tag in p.chemistry_tags]:
                    all_tags_present = False
                    break
            if all_tags_present:
                active_bonuses.append(bonus_info)
                print(f"Chemistry activated: {bonus_info['name']}")
        return active_bonuses

    def apply_bonuses_to_player_stats(self, roster_players, active_bonuses):
        for player in roster_players:
            player.reset_stats()
        for bonus in active_bonuses:
            target_stat = bonus['target_stat']
            amount = bonus['amount']
            bonus_type = bonus['bonus_type']
            for player in roster_players:
                if target_stat.startswith("overall_team_"):
                    continue
                current_val = player.get_stat(target_stat)
                if current_val is not None:
                    if bonus_type == "percentage":
                        player.apply_stat_boost(target_stat, current_val * amount)
                    elif bonus_type == "flat":
                        player.apply_stat_boost(target_stat, amount)

    def get_chemistry_conflicts(self, roster_players):
        return []

    def get_potential_bonuses(self, roster_players):
