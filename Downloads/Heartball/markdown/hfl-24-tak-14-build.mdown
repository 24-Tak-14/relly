# systems/ultimate_team/spirit_chief_hut_foundry.py
import json
import os
from collections import defaultdict
from core.player import HUTPlayerCard
from config.settings import DATA_DIR

class SpiritChiefHUTFoundry:
    def __init__(self, ultimate_team_manager, data_path=DATA_DIR):
        self.ultimate_team_manager = ultimate_team_manager
        self.data_path = data_path
        self.foundry_parts_definitions = self._load_json(os.path.join(data_path, "foundry_parts.json"))
        self.blueprint_definitions = self._load_json(os.path.join(data_path, "blueprints.json"))
        self.mod_definitions = self._load_json(os.path.join(data_path, "mod_definitions.json"))
        print("Spirit Chief HUT Foundry initialized.")

    def _load_json(self, filepath):
        if not os.path.exists(filepath):
            print(f"Warning: {filepath} not found. Returning empty data.")
            return []
        try:
            with open(filepath, 'r') as f:
                return json.load(f)
        except json.JSONDecodeError:
            print(f"Error decoding JSON from {filepath}. Returning empty data.")
            return []

    def _get_user_foundry_parts(self, user_id):
        user_data = self.ultimate_team_manager._load_json(self.ultimate_team_manager.user_rosters_path)
        return user_data.get(user_id, {}).get('foundry_parts', defaultdict(int))

    def _update_user_foundry_parts(self, user_id, part_id, quantity):
        user_data = self.ultimate_team_manager._load_json(self.ultimate_team_manager.user_rosters_path)
        if user_id not in user_data:
            user_data[user_id] = {'rosters': {}, 'inventory': [], 'foundry_parts': defaultdict(int)}
        current_parts = defaultdict(int, user_data[user_id].get('foundry_parts', {}))
        current_parts[part_id] += quantity
        if current_parts[part_id] < 0:
            current_parts[part_id] = 0
        user_data[user_id]['foundry_parts'] = dict(current_parts)
        self.ultimate_team_manager._save_json(user_data, self.ultimate_team_manager.user_rosters_path)
        print(f"User {user_id} now has {current_parts[part_id]} of {part_id}.")

    def disenchant_item(self, user_id, item_type, item_id):
        yield_parts = {}
        if item_type == 'player_card':
            player_card_obj = next((p for p in self.ultimate_team_manager.get_user_inventory(user_id) if p.player_id == item_id), None)
            if not player_card_obj:
                print(f"Error: Player card '{item_id}' not found in {user_id}'s inventory.")
                return False
            if player_card_obj.rarity == "Iron":
                yield_parts = {"generic_scraps": 10}
            elif player_card_obj.rarity == "Gold":
                yield_parts = {"offensive_essence": 5, "defensive_core": 5}
            elif player_card_obj.rarity == "@~ZORI~@":
                yield_parts = {"rare_crystals": 10, "super_essence": 20}
            else:
                print(f"No disenchantment yield defined for {player_card_obj.rarity} player cards.")
                return False
            if not self.ultimate_team_manager.remove_player_from_inventory(user_id, item_id):
                return False
        elif item_type == 'mod_token':
            mod_def = next((m for m in self.mod_definitions if m['mod_id'] == item_id), None)
            if not mod_def:
                print(f"Error: Mod '{item_id}' definition not found.")
                return False
            yield_parts = mod_def.get('disenchant_yield', {})
            if not yield_parts:
                print(f"No disenchantment yield defined for mod '{item_id}'.")
                return False
            print(f"Simulating removal of mod token '{item_id}' from {user_id}'s inventory.")
        else:
            print(f"Error: Unsupported item type for disenchantment: {item_type}.")
            return False
        for part_id, quantity in yield_parts.items():
            self._update_user_foundry_parts(user_id, part_id, quantity)
        print(f"Successfully disenchanted {item_id}. Yielded: {yield_parts}")
        return True

    def craft_player_card(self, user_id, blueprint_id):
        blueprint = next((bp for bp in self.blueprint_definitions if bp['blueprint_id'] == blueprint_id), None)
        if not blueprint:
            print(f"Error: Blueprint '{blueprint_id}' not found.")
            return None
        if blueprint['item_type_to_craft'] != 'player_card':
            print(f"Error: Blueprint '{blueprint_id}' crafts a '{blueprint['item_type_to_craft']}', not a player card.")
            return None
        user_parts = self._get_user_foundry_parts(user_id)
        can_craft = True
        required_parts = defaultdict(int)
        for req in blueprint['requirements']:
            if req['type'] == 'foundry_part':
                required_parts[req['id']] += req['quantity']
                if user_parts[req['id']] < req['quantity']:
                    can_craft = False
                    print(f"Missing {req['quantity'] - user_parts[req['id']]} of {req['id']}.")
        if not can_craft:
            print("Error: Not enough Foundry Parts or other requirements to craft.")
            return None
        for part_id, quantity in required_parts.items():
            self._update_user_foundry_parts(user_id, part_id, -quantity)
        new_player_card = self.ultimate_team_manager.get_player_card_template(blueprint['target_item_id'])
        if new_player_card:
            self.ultimate_team_manager.add_player_to_inventory(user_id, new_player_card.player_id)
            print(f"Successfully crafted {new_player_card.name} for user {user_id}!")
            return new_player_card
        print(f"Error: Could not find player template for {blueprint['target_item_id']}.")
        return None

    def apply_mod_to_player(self, user_id, player_card_id, mod_id):
        player_card_obj = next((p for p in self.ultimate_team_manager.get_user_inventory(user_id) if p.player_id == player_card_id), None)
        if not player_card_obj:
            print(f"Error: Player card '{player_card_id}' not found in {user_id}'s inventory.")
            return False
        mod_def = next((m for m in self.mod_definitions if m['mod_id'] == mod_id), None)
        if not mod_def:
            print(f"Error: Mod definition '{mod_id}' not found.")
            return False
        if len(player_card_obj.current_mods) >= player_card_obj.mod_slots:
            print(f"Error: Player card '{player_card_obj.name}' has no available mod slots.")
            return False
        if mod_id in player_card_obj.current_mods:
            print(f"Error: Mod '{mod_id}' is already applied to '{player_card_obj.name}'.")
            return False
        user_parts = self._get_user_foundry_parts(user_id)
        can_apply = True
        required_parts = defaultdict(int)
        for cost_item in mod_def.get('mod_cost_parts', []):
            if cost_item['type'] == 'foundry_part':
                required_parts[cost_item['id']] += cost_item['quantity']
                if user_parts[cost_item['id']] < cost_item['quantity']:
                    can_apply = False
                    print(f"Missing {cost_item['quantity'] - user_parts[cost_item['id']]} of {cost_item['id']} for mod.")
        if not can_apply:
            print("Error: Not enough Foundry Parts or required mod token to apply mod.")
            return False
        for part_id, quantity in required_parts.items():
            self._update_user_foundry_parts(user_id, part_id, -quantity)
        player_card_obj.add_mod(mod_id)
        if 'effect' in mod_def:
            if 'stat_boosts' in mod_def['effect']:
                for stat, value in mod_def['effect']['stat_boosts'].items():
                    player_card_obj.apply_stat_boost(stat, value)
            if 'new_tags' in mod_def['effect']:
                for tag in mod_def['effect']['new_tags']:
                    if tag not in player_card_obj.chemistry_tags:
                        player_card_obj.chemistry_tags.append(tag)
        print(f"Successfully applied mod '{mod_id}' to {player_card_obj.name} for user {user_id}.")
        self.ultimate_team_manager._save_user_data(user_id)
        return True

    def get_user_foundry_parts_display(self, user_id):
        return dict(self._get_user_foundry_parts(user_id))

    def get_craftable_blueprints(self, user_id):
        craftable = []
        user_parts = self._get_user_foundry_parts(user_id)
        for bp in self.blueprint_definitions:
            can_craft = True
            for req in bp['requirements']:
                if req['type'] == 'foundry_part':
                    if user_parts[req['id']] < req['quantity']:
                        can_craft = False
                        break
            if can_craft:
                craftable.append(bp)
        return craftable

    def get_applicable_mods(self, user_id, player_card_id):
        applicable_mods = []
        player_card_obj = next((p for p in self.ultimate_team_manager.get_user_inventory(user_id) if p.player_id == player_card_id), None)
        if not player_card_obj or len(player_card_obj.current_mods) >= player_card_obj.mod_slots:
            return []
        user_parts = self._get_user_foundry_parts(user_id)
        for mod_def in self.mod_definitions:
            if mod_def['mod_id'] in player_card_obj.current_mods:
                continue
            can_apply = True
            for cost_item in mod_def.get('mod_cost_parts', []):
                if cost_item['type'] == 'foundry_part':
                    if user_parts[cost_item['id']] < cost_item['quantity']:
                        can_apply = False
                        break
            if can_apply:
                applicable_mods.append(mod_def)
        return applicable_mods
