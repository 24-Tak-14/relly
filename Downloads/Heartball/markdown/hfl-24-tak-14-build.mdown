from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
from typing import List, Dict
from .ultimate_team_manager import UltimateTeamManager
from .hut_marketplace import HUTMarketplace
from .spirit_chief_hut_foundry import SpiritChiefHUTFoundry
from .hut_event_scheduler import HUTEventScheduler

app = FastAPI()
hut_manager = UltimateTeamManager()
marketplace = HUTMarketplace(hut_manager)
foundry = SpiritChiefHUTFoundry(hut_manager)
event_scheduler = HUTEventScheduler(hut_manager)

class PlayerCard(BaseModel):
    player_id: str
    name: str
    position: str
    rarity: str
    base_stats: Dict
    chemistry_tags: List[str]
    buildable_player: bool
    mod_slots: int
    current_mods: List[str]

class Roster(BaseModel):
    roster_id: str
    roster_name: str
    players: List[PlayerCard]
    total_salary_cap_used: int
    active_chemistry: List[str]

class Listing(BaseModel):
    listing_id: str
    item_id: str
    seller_id: str
    start_price: float
    buy_now_price: float = None
    end_time: float
    current_bid: float
    highest_bidder_id: str = None
    item_type: str

class FoundryPart(BaseModel):
    id: str
    quantity: int

class Blueprint(BaseModel):
    blueprint_id: str
    name: str
    item_type_to_craft: str
    target_item_id: str
    requirements: List[Dict]
    description: str

class Mod(BaseModel):
    mod_id: str
    name: str
    description: str
    effect: Dict
    mod_cost_parts: List[Dict]
    disenchant_yield: Dict

@app.get("/roster/{user_id}/{roster_id}", response_model=Roster)
async def get_roster(user_id: str, roster_id: str):
    roster = hut_manager.load_roster(user_id, roster_id)
    if not roster:
        raise HTTPException(status_code=404, detail="Roster not found")
    players = [
        PlayerCard(
            player_id=p.player_id,
            name=p.name,
            position=p.position,
            rarity=p.rarity,
            base_stats=p.base_stats,
            chemistry_tags=p.chemistry_tags,
            buildable_player=p.buildable_player,
            mod_slots=p.mod_slots,
            current_mods=p.current_mods
        ) for p in roster['players']
    ]
    return Roster(
        roster_id=roster_id,
        roster_name=roster['roster_name'],
        players=players,
        total_salary_cap_used=roster['total_salary_cap_used'],
        active_chemistry=roster['active_chemistry']
    )

@app.post("/roster/{user_id}")
async def create_roster(user_id: str, roster_name: str):
    roster_id = hut_manager.create_roster(user_id, roster_name)
    return {"roster_id": roster_id}

@app.post("/roster/{user_id}/{roster_id}/add_player")
async def add_player_to_roster(user_id: str, roster_id: str, player_card_id: str, position: str):
