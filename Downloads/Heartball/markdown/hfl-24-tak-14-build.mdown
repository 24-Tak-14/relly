# systems/ultimate_team/ultimate_team_manager.py
import json
import os
from collections import defaultdict
from core.player import HUTPlayerCard
from config.settings import DATA_DIR

class UltimateTeamManager:
    def __init__(self, data_path=DATA_DIR, player_pool_file="hut_player_pool.json", user_rosters_file="hut_user_rosters.json"):
        self.player_pool_path = os.path.join(data_path, player_pool_file)
        self.user_rosters_path = os.path.join(data_path, user_rosters_file)
        self._player_pool_data = self._load_json(self.player_pool_path)
        self.active_user_rosters = defaultdict(dict)
        self.player_inventory = defaultdict(list)
        self._load_initial_user_rosters()
        self._initialize_player_cards()

    def _load_json(self, filepath):
        if not os.path.exists(filepath):
            print(f"Warning: {filepath} not found. Returning empty data.")
            return []
        try:
            with open(filepath, 'r') as f:
                return json.load(f)
        except json.JSONDecodeError:
            print(f"Error decoding JSON from {filepath}. Returning empty data.")
            return []

    def _save_json(self, data, filepath):
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        with open(filepath, 'w') as f:
            json.dump(data, f, indent=2)

    def _initialize_player_cards(self):
        self._player_card_objects = {}
        for player_data in self._player_pool_data:
            card = HUTPlayerCard(
                player_data['player_id'],
                player_data['name'],
                player_data['position'],
                player_data['base_stats'],
                player_data['rarity'],
                player_data['chemistry_tags'],
                player_data['buildable_player'],
                player_data['mod_slots']
            )
            self._player_card_objects[player_data['player_id']] = card

    def get_player_card_template(self, player_id):
        if player_id in self._player_card_objects:
            template = self._player_card_objects[player_id]
            return HUTPlayerCard(
                template.player_id, template.name, template.position,
                dict(template.base_stats), template.rarity,
                list(template.chemistry_tags), template.buildable_player,
                template.mod_slots
            )
        return None

    def _load_initial_user_rosters(self):
        user_data = self._load_json(self.user_rosters_path)
        for user_id, data in user_data.items():
            self.active_user_rosters[user_id] = {}
            for roster_id, roster_info in data.get('rosters', {}).items():
                roster_obj = {
                    "roster_name": roster_info['roster_name'],
                    "players": [],
                    "total_salary_cap_used": roster_info.get('total_salary_cap_used', 0),
                    "active_chemistry": roster_info.get('active_chemistry', [])
                }
                for p_data in roster_info['players']:
                    player_card = self.get_player_card_template(p_data['player_id'])
                    if player_card:
                        player_card.position = p_data['position']
                        player_card.current_mods = p_data.get('current_mods', [])
                        roster_obj['players'].append(player_card)
                self.active_user_rosters[user_id][roster_id] = roster_obj
            self.player_inventory[user_id] = [
                self.get_player_card_template(pid) for pid in data.get('inventory', [])
                if self.get_player_card_template(pid) is not None
            ]

    def create_roster(self, user_id, roster_name):
        new_roster_id = f"roster_{len(self.active_user_rosters[user_id]) + 1}_{roster_name.replace(' ', '_').lower()}"
        self.active_user_rosters[user_id][new_roster_id] = {
            "roster_name": roster_name,
            "players": [],
            "total_salary_cap_used": 0,
            "active_chemistry": []
        }
        print(f"Roster '{roster_name}' created for user {user_id} with ID {new_roster_id}.")
        self._save_user_data(user_id)
        return new_roster_id

    def load_roster(self, user_id, roster_id):
        return self.active_user_rosters[user_id].get(roster_id)

    def save_roster(self, user_id, roster_id):
        self._save_user_data(user_id)
        print(f"Roster '{roster_id}' for user {user_id} saved.")

    def add_player_to_roster(self, user_id, roster_id, player_card_id, position):
        roster = self.active_user_rosters[user_id].get(roster_id)
        player_card = self.get_player_card_template(player_card_id)

        if not roster or not player_card:
            print("Error: Roster or player card not found.")
            return False

        existing_player_at_pos = next((p for p in roster['players'] if p.position == position), None)
        if existing_player_at_pos:
            print(f"Position {position} already filled by {existing_player_at_pos.name}.")
            return False

        player_card.position = position
        roster['players'].append(player_card)
        print(f"{player_card.name} added to {roster['roster_name']} at {position}.")
        self._save_user_data(user_id)
        return True

    def remove_player_from_roster(self, user_id, roster_id, player_card_id):
        roster = self.active_user_rosters[user_id].get(roster_id)
        if not roster:
            print("Error: Roster not found.")
            return False

        initial_len = len(roster['players'])
        roster['players'] = [p for p in roster['players'] if p.player_id != player_card_id]
        if len(roster['players']) < initial_len:
            print(f"Player {player_card_id} removed from {roster['roster_name']}.")
            self._save_user_data(user_id)
            return True
        print(f"Player {player_card_id} not found in {roster['roster_name']}.")
        return False

    def validate_lineup(self, user_id, roster_id):
        roster = self.active_user_rosters[user_id].get(roster_id)
        if not roster:
            return False, "Roster not found."

        qbs = [p for p in roster['players'] if p.position == 'QB1']
        if not qbs:
            return False, "Roster must have at least one Quarterback."
        return True, "Roster is valid."

    def get_active_roster(self, user_id, roster_id=None):
        if roster_id:
            return self.active_user_rosters[user_id].get(roster_id)
        return next(iter(self.active_user_rosters[user_id].values()), None)

    def add_player_to_inventory(self, user_id, player_card_id):
        player_card = self.get_player_card_template(player_card_id)
        if player_card:
            self.player_inventory[user_id].append(player_card)
            print(f"{player_card.name} added to user {user_id}'s inventory.")
            self._save_user_data(user_id)
            return True
        return False

    def remove_player_from_inventory(self, user_id, player_card_id):
        initial_len = len(self.player_inventory[user_id])
        self.player_inventory[user_id] = [p for p in self.player_inventory[user_id] if p.player_id != player_card_id]
        if len(self.player_inventory[user_id]) < initial_len:
            print(f"Player {player_card_id} removed from user {user_id}'s inventory.")
            self._save_user_data(user_id)
            return True
        print(f"Player {player_card_id} not found in user {user_id}'s inventory.")
        return False

    def get_user_inventory(self, user_id):
        return self.player_inventory[user_id]

    def integrate_dubble_fantasy_points(self, user_id, contest_result):
        points_earned = contest_result.get('points_earned', 0)
        hut_points = points_earned * 0.1
        print(f"User {user_id} earned {points_earned} Dubble Fantasy points, converted to {hut_points} HUT points.")
        return hut_points

    def _save_user_data(self, user_id):
        all_user_data = self._load_json(self.user_rosters_path)
        serializable_rosters = {}
        for roster_id, roster_obj in self.active_user_rosters[user_id].items():
            serializable_players = [
                {
                    'player_id': player.player_id,
                    'position': player.position,
                    'current_mods': player.current_mods
                } for player in roster_obj['players']
            ]
            serializable_rosters[roster_id] = {
                'roster_name': roster_obj['roster_name'],
                'players': serializable_players,
                'total_salary_cap_used': roster_obj['total_salary_cap_used'],
                'active_chemistry': roster_obj['active_chemistry']
            }
        serializable_inventory = [p.player_id for p in self.player_inventory[user_id]]
        all_user_data[user_id] = {
            'rosters': serializable_rosters,
            'inventory': serializable_inventory,
            'foundry_parts': self._load_json(self.user_rosters_path).get(user_id, {}).get('foundry_parts', {})
        }
        self._save_json(all_user_data, self.user_rosters_path)
```

